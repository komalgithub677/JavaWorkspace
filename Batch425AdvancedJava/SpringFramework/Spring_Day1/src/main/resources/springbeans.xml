<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN"
        "http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>

	<!-- Address Bean -->
	<bean id="c" class="com.tka.Address">
		<constructor-arg index="0" value="1"/>
		<constructor-arg index="1" value="Pune"/>
		<constructor-arg index="2" value="Maharashtra"/>
	</bean>

	<!-- Person Bean -->
	<bean id="per" class="com.tka.Person">
		<constructor-arg index="0" value="123"/>
		<constructor-arg index="1" value="Komal"/>
		<constructor-arg index="2" ref="c"/>
	</bean>

</beans>